                         <property name="styleSheet">
                          <string notr="true">/* Базовый вид кнопки */
QPushButton {
    border-image: url(:/assets/ckal page/info_btn.svg) 10 10 10 10;
color: #4A4A4A;
    font-size: 14px;
    min-width: 21px;
    min-height: 21px;
}

/* При наведении мышкой */
QPushButton:hover {
    border-image: url(:/assets/ckal page/info_btn_hover.svg) 10 10 10 10;
}

/* В момент самого нажатия (физический клик) */
QPushButton:pressed {
    border-image: url(:/assets/ckal page/info_btn_pressed.svg) 10 10 10 10;
    padding-top: 4px;
/* Эффект проседания текста */
}
</string>
