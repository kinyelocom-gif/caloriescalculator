    border-image: url(:/assets/ckal page/upload_field.svg) 0 0 0 0;
background-color: transparent;
    border: none;

    /* Жесткая фиксация размера */
    min-width: 280px;
    max-width: 280px;
    min-height: 56px;
    max-height: 56px;
}

#name_frame:hover {
    /* Меняем только путь к картинке */
