                         <property name="styleSheet">
                          <string notr="true">
QProgressBar {
    border: 1px solid transparent;        
    background-color: #CAC4D0; 
    border-radius: 4px;     
    height: 15px;          
	text-align: center; 	


}


QProgressBar::chunk {
    background-color: #6750A4;
    border-radius: 4px;       
	margin: 0px ;
	border: none;
}



</string>
