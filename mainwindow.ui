                          </sizepolicy>
                         </property>
                         <property name="styleSheet">
                          <string notr="true">#ckal_bar_label {
	background-color: rgba(0, 0, 0, 0) !important; /* Полная прозрачность */
    background: none !important;                  /* Отключаем любые заливки */
    border: none !important;                      /* Убираем рамки */
}</string>
